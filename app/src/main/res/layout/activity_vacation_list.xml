<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.example.d308project.ui.VacationList">

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/floatingActionButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="2dp"
        android:clickable="true"
        app:srcCompat="@drawable/baseline_add_24"
        tools:layout_editor_absoluteX="339dp"
        tools:layout_editor_absoluteY="678dp" />

    <ScrollView
        android:layout_width="409dp"
        android:layout_height="200dp"
        android:background="#9FA8DA"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <TextView
        android:id="@+id/textBermuda"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bermuda Trip"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="10dp"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/textLondon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="London Trip"
        app:layout_constraintTop_toBottomOf="@id/textBermuda"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="10dp"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/textSpring"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Spring Break"
        app:layout_constraintTop_toBottomOf="@id/textLondon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="10dp"
        android:layout_marginTop="16dp"/>

    <EditText
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/textLondon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="second"></EditText>
</androidx.constraintlayout.widget.ConstraintLayout>