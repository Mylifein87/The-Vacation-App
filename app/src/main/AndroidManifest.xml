<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.D308Project">
        <activity
            android:name=".ui.ExcursionDetails"
            android:exported="false" />
        <activity
            android:name="com.example.d308project.ui.VacationDetails"
            android:exported="false"
            android:label="Vacation Details and Excursions List"
            android:parentActivityName="com.example.d308project.ui.VacationList" />
        <activity
            android:name="com.example.d308project.ui.VacationList"
            android:exported="false"
            android:label="Vacation List"
            android:parentActivityName="com.example.d308project.ui.MainActivity" />
        <activity
            android:name="com.example.d308project.ui.MainActivity"
            android:exported="true"
            android:label="Main Activity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />
    </application>

</manifest>